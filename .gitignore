# All folders starting with _ are local.
_*/

# Compiled python files.
*.py[cod]

# Visual Studio files.
/.vs
**/.vscode/ipch

# macOS files.
.DS_Store

# Generated license file.
PACKAGE-DEPS.yaml

# packman .user config
*.packman.xml.user

# Generated packman XML files from templates (managed by select_kit_version tool)
tools/deps/kit-sdk.packman.xml
tools/deps/kit-cae-deps.packman.xml

# Kit selection state file (managed by select_kit_version tool)
.kit_selection.json

# Generated app files/symlinks from templates (managed by select_kit_version tool)
source/apps/default_stream.kit
source/apps/kit_base_editor.kit
source/apps/kit_cae_editor.kit
source/apps/kit_cae_streaming.kit

# kit user config
deps/**/user.toml

# vscode settings are copied and filled in from 'settings.json.template'
.vscode/settings.json

# PyCharm files.
/.idea/

# Linux in docker build $HOME dirs
/.nvidia-omniverse
/.local
/.cache

# Omniverse EULA breadcrumb
/.omniverse_eula_accepted.txt

# Streaming EventTrace
*.etli

/logs

data/*.usda

# Format tool cache
.lastformat
