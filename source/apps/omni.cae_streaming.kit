[package]
title = "Omni CAE Editor Streaming"
version = "2.0.0"
description = "Configuration for streaming deployments of Omni CAE Editor"
keywords = ["experience", "app", "dev", "streaming"]
template_name = "omni.streaming_configuration"

[dependencies]
"kit_cae_streaming" = {}

[settings.persistent.app.stage]
upAxis = 'Z'

[settings.app.exts]
folders.'++' = [  # Search paths for extensions.
	"${app}/../exts",
    "${app}/../apps",
	"${app}/../extscache/"
]

[settings.app.rendergraph]
maxFramesInFlight = 2

[settings.log]
file = "logs/omni.cae_streaming.kit.log"
fileLogLevel = "info" # more verbose logging
enableStandardStreamOutput = true
outputStreamLevel = "warning"
