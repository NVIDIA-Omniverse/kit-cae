[package]
title = "Omni CAE Editor (VTK)"
version = "2.0.0"
description = "Kit-CAE Sample Application with VTK"
keywords = ["app"]
template_name = "kit_base_editor"

[dependencies]
"kit_cae_editor" = {}

# VTK-based extensions
"omni.cae.delegate.vtk" = {}
"omni.cae.importer.vtk" = {}
"omni.cae.vtk" = {}  # Legacy VTK extension with operator commands

[settings.persistent.app.stage]
upAxis = 'Z'

[settings.app]
window.title = "Omni CAE Editor (with VTK) (Kit: ${kit_version_short}.${kit_version_patch})"

[settings.app.exts]
folders.'++' = [  # Search paths for extensions.
	"${app}/../exts",
    "${app}/../apps",
	"${app}/../extscache/"
]

[settings.log]
file = "logs/omni.cae_vtk.kit.log"
fileLogLevel = "info" # more verbose logging
enableStandardStreamOutput = true
outputStreamLevel = "warning"
