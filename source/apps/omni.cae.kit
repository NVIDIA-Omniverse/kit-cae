[package]
title = "Omni CAE Editor"
version = "2.0.0"
description = "Kit-CAE Sample Application"
keywords = ["app"]  # That makes it browsable in UI with "app" filter
template_name = "kit_base_editor"

[dependencies]
"kit_cae_editor" = {}

[settings.persistent.app.stage]
upAxis = 'Z'

[settings.app]
window.title = "Omni CAE Editor (Kit: ${kit_version_short}.${kit_version_patch})"

[settings.app.exts]
folders.'++' = [  # Search paths for extensions.
	"${app}/../exts",
    "${app}/../apps",
	"${app}/../extscache/"
]

[settings.log]
file = "logs/omni.cae.kit.log"
fileLogLevel = "info" # more verbose logging
enableStandardStreamOutput = true
outputStreamLevel = "warning"

[[test]]
args = [
	"--/app/file/ignoreUnsavedOnExit=true"
]

[template]
type = "ApplicationTemplate" # Repo Template Metadata
