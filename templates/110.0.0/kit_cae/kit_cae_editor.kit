[package]
target.kit = ["110.0.0"]

[dependencies]
# Kit-Kernel specific base editor.
"kit_base_editor" = {}
"omni.cae.bundle" = {}

[settings.app.exts]
folders.'++' = [  # Search paths for extensions.
	"${app}/../exts",
    "${app}/../apps",
	"${app}/../extscache/"
]


